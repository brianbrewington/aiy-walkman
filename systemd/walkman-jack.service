[Unit]
Description=Walkman: mute built-in speaker when headphones are plugged in
After=sound.target alsa-restore.service
Wants=sound.target

[Service]
Type=simple
# root: needs to read /dev/input/event* and set the ALSA control.
User=root
ExecStart=/usr/bin/python3 /home/brew/walkman/src/walkman/jack_monitor.py
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
