# Walkman Mopidy config (example / template)
#
# Step-1 test version: run as user `brew` from ~/.config/mopidy/mopidy.conf.
# Step 2 will adapt this for the system `mopidy` service (paths/permissions).
#
# Audio goes to the AIY Voice Bonnet (RT5645) ALSA card brought up in Step 0.
# Control is via Mopidy's built-in HTTP JSON-RPC (port 6680).

[core]
restore_state = true

[audio]
mixer = software
# Bonnet card id is "aiyvoicebonnet" (see docs/STEP0-NOTES.md). plughw lets
# GStreamer resample to whatever the codec wants.
output = alsasink device=plughw:CARD=aiyvoicebonnet

[http]
enabled = true
hostname = 127.0.0.1
port = 6680

[youtube]
enabled = true
# Use the YouTube Music API (ytmusicapi) for the user's subscription/playlists.
musicapi_enabled = true
# Browser/header (cookie) auth JSON — generated by scripts/ytmusic_auth_from_curl.py.
# Per-device credential: this path is the only thing that changes between units
# (that + the playlist id + hostname). Keep it mode 600.
musicapi_browser_authentication_file = /home/brew/.config/walkman/ytmusic-auth.json
# Fetch audio streams with yt-dlp (more robust than the abandoned pytube/youtube-dl).
youtube_dl_package = yt_dlp
api_enabled = false
playlist_max_videos = 60

# NOTE: musicapi_cookiefile is NON-FUNCTIONAL in Mopidy-YouTube 4.0.2 (commented
# out in the extension). Use musicapi_browser_authentication_file above.
